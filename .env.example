# Supabase Cloud
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App environment (development | staging | production)
EXPO_PUBLIC_APP_ENV=development

# Apple Developer Team ID — required for OneSignal NSE signing on physical devices
# Find it at: developer.apple.com → Account → Membership → Team ID
# APPLE_TEAM_ID=XXXXXXXXXX

# Google OAuth (for native Google Sign-In)
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id

# OneSignal Push Notifications
# EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# RevenueCat (for IAP)
# EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=your-ios-key
# EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=your-android-key

# Feature Flags (default: all enabled — set to 'false' to disable)
# Phase 1: hides UI sections and feature cards
# Phase 2 (future): also excludes native plugins from build (requires prebuild)
#
# Note: NOTIFICATIONS and IAP both depend on AUTH for user ID sync.
#       Disabling AUTH without disabling the others will show a dev warning.
#
# EXPO_PUBLIC_FEATURE_AUTH=false          # hides Account section; skips login screen
# EXPO_PUBLIC_FEATURE_NOTIFICATIONS=false # hides Notifications section + Devices screen
# EXPO_PUBLIC_FEATURE_IAP=false           # hides Pro section + Paywall
# EXPO_PUBLIC_FEATURE_FEEDBACK=false      # hides Feedback section in Settings

# FeedbackBridge — in-app feedback widget (posts to a Relay Worker)
# Required when FEATURE_FEEDBACK is on; the Settings entry is hidden when missing.
# EXPO_PUBLIC_FEEDBACK_RELAY_ENDPOINT=https://your-relay.example.com
# EXPO_PUBLIC_FEEDBACK_API_KEY=fbk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EXPO_PUBLIC_FEEDBACK_APP_ID=com.yourco.yourapp  # optional, defaults to bundle id
